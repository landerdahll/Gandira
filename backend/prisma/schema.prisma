generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  PRODUCER
  STAFF
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  FINISHED
}

enum TicketType {
  GENERAL
  VIP
  BACKSTAGE
  ONLINE
}

enum BatchStatus {
  ACTIVE
  SOLD_OUT
  EXPIRED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PROCESSING
  PAID
  CANCELLED
  REFUNDED
  EXPIRED
}

enum TicketStatus {
  ACTIVE
  TRANSFER_PENDING
  USED
  CANCELLED
  TRANSFERRED
}

enum TicketTransferStatus {
  PENDING_REGISTRATION
  COMPLETED
  CANCELLED
  EXPIRED
}

enum CheckInMethod {
  QR_CODE
  MANUAL
  AT_DOOR
}

enum ClubBenefitUsageStatus {
  RESERVED
  CONFIRMED
  RELEASED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  password   String
  name       String
  phone      String?
  cpf        String?   @unique
  role       Role      @default(CUSTOMER)
  gender     Gender?
  birthDate  DateTime?
  avatarUrl  String?
  isVerified Boolean   @default(false)
  isActive   Boolean   @default(true)

  events                  Event[]
  orders                  Order[]
  checkIns                CheckIn[]                @relation("StaffCheckIns")
  refreshTokens           RefreshToken[]
  auditLogs               AuditLog[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  ownedTickets            Ticket[]                 @relation("TicketOwner")
  sentTicketTransfers     TicketTransfer[]         @relation("TransferSender")
  receivedTicketTransfers TicketTransfer[]         @relation("TransferRecipient")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([cpf])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model Event {
  id         String @id @default(cuid())
  producerId String
  producer   User   @relation(fields: [producerId], references: [id])

  title       String
  description String  @db.Text
  slug        String  @unique
  coverImage  String?
  bannerImage String?

  venue     String
  address   String
  city      String
  state     String
  zipCode   String?
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)

  startDate DateTime
  endDate   DateTime
  doorsOpen DateTime?

  ageRating Int      @default(0)
  category  String?
  tags      String[] @default([])

  status               EventStatus @default(DRAFT)
  allowTicketTransfers Boolean     @default(true)

  batches           Batch[]
  orders            Order[]
  checkIns          CheckIn[]
  tickets           Ticket[]
  coupons           Coupon[]
  ticketTransfers   TicketTransfer[]
  clubBenefitUsages ClubBenefitUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([producerId])
  @@index([status, startDate])
  @@index([city, status])
}

model Batch {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  quantity    Int
  sold        Int     @default(0)

  startsAt DateTime
  endsAt   DateTime

  ticketType TicketType  @default(GENERAL)
  status     BatchStatus @default(ACTIVE)
  sortOrder  Int         @default(0)

  tickets    Ticket[]
  orderItems OrderItem[]
  clubBenefitUsages ClubBenefitUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@index([eventId, status])
}

model Order {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  status OrderStatus @default(PENDING)

  subtotal    Decimal @db.Decimal(10, 2)
  platformFee Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  stripePaymentIntentId String? @unique
  stripeChargeId        String?

  couponId       String?
  coupon         Coupon? @relation(fields: [couponId], references: [id])
  discountAmount Decimal @default(0) @db.Decimal(10, 2)

  cancelledAt    DateTime?
  cancelReason   String?
  refundedAt     DateTime?
  stripeRefundId String?

  expiresAt DateTime

  items                 OrderItem[]
  tickets               Ticket[]
  reservedClubBenefits  ClubBenefitUsage[] @relation("ClubBenefitReservedOrder")
  confirmedClubBenefits ClubBenefitUsage[] @relation("ClubBenefitConfirmedOrder")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([eventId])
  @@index([status])
  @@index([stripePaymentIntentId])
  @@index([expiresAt, status])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])
  batchId String
  batch   Batch  @relation(fields: [batchId], references: [id])

  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([orderId])
}

model Ticket {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id])
  batchId     String
  batch       Batch  @relation(fields: [batchId], references: [id])
  eventId     String
  event       Event  @relation(fields: [eventId], references: [id])
  ownerUserId String
  owner       User   @relation("TicketOwner", fields: [ownerUserId], references: [id])

  // Token criptograficamente aleatório — conteúdo do QR Code
  token String @unique @default(cuid())

  status TicketStatus @default(ACTIVE)

  holderName  String?
  holderEmail String?
  holderCpf   String?

  qrCodeUrl String?

  checkIn   CheckIn?
  transfers TicketTransfer[]
  history   TicketHistory[]

  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([orderId])
  @@index([batchId])
  @@index([eventId, status])
  @@index([ownerUserId, status])
}

model TicketTransfer {
  id                   String               @id @default(cuid())
  ticketId             String
  ticket               Ticket               @relation(fields: [ticketId], references: [id])
  eventId              String
  event                Event                @relation(fields: [eventId], references: [id])
  senderUserId         String
  sender               User                 @relation("TransferSender", fields: [senderUserId], references: [id])
  recipientUserId      String?
  recipient            User?                @relation("TransferRecipient", fields: [recipientUserId], references: [id])
  recipientEmail       String
  status               TicketTransferStatus
  invitationTokenHash  String?              @unique
  requestedAt          DateTime             @default(now())
  completedAt          DateTime?
  cancelledAt          DateTime?
  expiresAt            DateTime?
  previousQrIdentifier String?
  newQrIdentifier      String?
  cancellationReason   String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  history TicketHistory[]

  @@index([ticketId, status])
  @@index([senderUserId, requestedAt])
  @@index([recipientUserId, requestedAt])
  @@index([recipientEmail])
  @@index([eventId, requestedAt])
}

model TicketHistory {
  id          String          @id @default(cuid())
  ticketId    String
  ticket      Ticket          @relation(fields: [ticketId], references: [id])
  transferId  String?
  transfer    TicketTransfer? @relation(fields: [transferId], references: [id])
  action      String
  actorUserId String?
  metadata    Json?
  createdAt   DateTime        @default(now())

  @@index([ticketId, createdAt])
  @@index([transferId, createdAt])
}

model CheckIn {
  id       String @id @default(cuid())
  ticketId String @unique
  ticket   Ticket @relation(fields: [ticketId], references: [id])
  eventId  String
  event    Event  @relation(fields: [eventId], references: [id])

  staffId String?
  staff   User?   @relation("StaffCheckIns", fields: [staffId], references: [id])

  method CheckInMethod @default(QR_CODE)
  notes  String?

  checkedAt DateTime @default(now())

  @@index([eventId])
  @@index([ticketId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model Coupon {
  id        String    @id @default(cuid())
  eventId   String
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  code      String
  discount  Decimal   @db.Decimal(5, 2)
  maxUses   Int?
  usedCount Int       @default(0)
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  orders    Order[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([eventId, code])
  @@index([eventId])
}

model AuditLog {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model ClubMember {
  id            String    @id @default(cuid())
  cpf           String    @unique @db.VarChar(11)
  name          String?
  email         String?
  phone         String?
  isActive      Boolean   @default(true)
  activatedAt   DateTime  @default(now())
  deactivatedAt DateTime?

  usages ClubBenefitUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([email])
  @@index([phone])
  @@index([isActive])
}

model ClubBenefitUsage {
  id           String                 @id @default(cuid())
  clubMemberId String
  clubMember   ClubMember             @relation(fields: [clubMemberId], references: [id], onDelete: Restrict)
  eventId      String
  event        Event                  @relation(fields: [eventId], references: [id], onDelete: Restrict)
  status       ClubBenefitUsageStatus @default(RESERVED)

  reservedOrderId  String? @unique
  reservedOrder    Order?  @relation("ClubBenefitReservedOrder", fields: [reservedOrderId], references: [id], onDelete: SetNull)
  confirmedOrderId String? @unique
  confirmedOrder   Order?  @relation("ClubBenefitConfirmedOrder", fields: [confirmedOrderId], references: [id], onDelete: SetNull)
  batchId          String?
  batch            Batch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  originalAmount Decimal? @db.Decimal(10, 2)
  discountAmount Decimal? @db.Decimal(10, 2)
  finalAmount    Decimal? @db.Decimal(10, 2)

  reservedAt           DateTime?
  reservationExpiresAt DateTime?
  confirmedAt          DateTime?
  releasedAt           DateTime?
  releaseReason        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clubMemberId, eventId])
  @@index([status, reservationExpiresAt])
  @@index([eventId, status])
}
