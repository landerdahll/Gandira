NODE_ENV=production
PORT=3001
APP_URL=https://seu-backend.onrender.com
FRONTEND_URL=https://seu-frontend.vercel.app
# Temporário: dispensa verificação de e-mail e registra links de demonstração nos logs
DEMO_EMAIL_MODE=false

DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

JWT_SECRET=gere-uma-string-aleatoria-de-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=gere-outra-string-aleatoria-de-32-chars
JWT_REFRESH_EXPIRES_IN=7d

STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP — deixe em branco para logar links no console (dev mode)
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=seu@gmail.com, SMTP_PASS=app-password-do-google
# Resend: SMTP_HOST=smtp.resend.com, SMTP_PORT=465, SMTP_USER=resend, SMTP_PASS=sua-api-key
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@outrahora.com

PLATFORM_FEE_PERCENT=10

THROTTLE_TTL=60
THROTTLE_LIMIT=30
